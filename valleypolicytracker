def main():
    rows, cutoff = collect()
    today = dt.datetime.now(PHX).date()
    state = load_state()
    new_events, new_state, first_run = compute_changes(rows, state, today)
    save_state(new_state)
    action_items = sorted(
        (r for r in rows if r.get("_action_days") is not None),
        key=lambda r: (r["_action_days"], r["city"]))

    # longitudinal archive: one aggregate snapshot per day (for month-over-month trends)
    ARCH = Path(__file__).parent / "archive.json"
    try:
        archive = json.loads(ARCH.read_text(encoding="utf-8"))
        if not isinstance(archive, list):
            archive = []
    except Exception:
        archive = []
    rk = Counter(status_rank(r.get("status", "")) for r in rows)
    snap = {"date": today.isoformat(), "total": len(rows),
            "topics": {t: sum(1 for r in rows if t in r["topics"]) for t in TOPIC_ORDER},
            "adopted": rk.get(3, 0), "failed": rk.get(-1, 0),
            "cities": sorted({r["city"] for r in rows})}
    archive = [s for s in archive if s.get("date") != today.isoformat()] + [snap]
    archive = archive[-400:]
    try:
        ARCH.write_text(json.dumps(archive, indent=1), encoding="utf-8")
    except Exception:
        pass

    print(f"   diff: {len(new_events)} change-event(s); {len(action_items)} upcoming hearing(s); "
          f"archive: {len(archive)} snapshot(s){' (baseline)' if first_run else ''}")
    OUT.mkdir(exist_ok=True)
    map_prebuilt = build_map_payload(rows)
    (OUT / "index.html").write_text(
        render_html(rows, cutoff, new_state["events"], action_items, first_run, len(archive),
                    map_payload=map_prebuilt[0], map_placed=map_prebuilt[1]),
        encoding="utf-8")
    (OUT / "ordinances.json").write_text(json.dumps({
        "generated": dt.datetime.now(PHX).isoformat(),
        "window_days": WINDOW_DAYS, "count": len(rows),
        "cities_live": [c[1] for c in LEGISTAR_CITIES], "items": rows,
    }, indent=2), encoding="utf-8")
    (OUT / "digest.txt").write_text(render_digest(rows, cutoff), encoding="utf-8")
    write_map(rows, OUT / "map.html", prebuilt=map_prebuilt)
    print(f"\nWrote {len(rows)} items -> {OUT}/index.html, map.html, ordinances.json, digest.txt")

if __name__ == "__main__":
    main()
