# Normalized item-type tags (for the type chip + the Type filter).
# Order matters: specific land-use actions first, generic vehicles after, so a
# "rezoning adopted by ordinance" tags as Rezoning, not Ordinance. Retune freely.
_KIND_RULES = [
    ("Rezoning",       ["rezon", "zoning map amendment", "map amendment", "zoning case",
                        "planned area development", "pad overlay", "official zoning map"]),
    ("Use permit",     ["use permit", "conditional use", "special use", "special permit"]),
    ("Variance",       ["variance"]),
    ("Dev/Site plan",  ["development plan", "site plan", "design review", "development review"]),
    ("Plan amend",     ["general plan", "specific plan amendment", "minor general plan",
                        "major general plan"]),
    ("Code/Text amend",["text amendment", "code amendment", "zoning text", "development code",
                        "ordinance text", "unified development"]),
    ("Plat/Subdiv",    ["subdivision", "preliminary plat", "final plat", "replat", " plat "]),
    ("Annexation",     ["annexation", "annex "]),
    ("ROW/Easement",   ["right-of-way", "right of way", "abandonment", "easement", "vacation of"]),
    ("Ordinance",      ["ordinance"]),
    ("Resolution",     ["resolution"]),
    ("Contract/IGA",   ["intergovernmental", " iga", "agreement", "contract", "procure",
                        "purchase", "award", "bid", "rfp"]),
    ("Plan/Study",     ["master plan", "action plan", "study", "update", "presentation",
                        "report", "briefing", "work session", "discussion", "plan "]),
    ("Grant/Funding",  ["grant", "funding", "appropriat", "bond", "budget", "sub-grant"]),
]

def classify_kind(r):
    hay = f"{r.get('title','')} {r.get('type','')}".lower()
    for label, kws in _KIND_RULES:
        if any(kw in hay for kw in kws):
            return label
    return "Other"

def status_class(s):
    s = (s or "").lower()
    if any(w in s for w in ["adopt", "approv", "enact", "pass"]): return "st-pass"
    if any(w in s for w in ["fail", "denied", "withdraw", "reject"]): return "st-fail"
    if any(w in s for w in ["pending", "hearing", "review", "introduc", "filed", "agenda"]): return "st-live"
    return "st-other"

def _short(s, n=104):
    s = (s or "").strip()
    return s if len(s) <= n else s[:n].rstrip() + "…"

def _when_label(d):
    return "today" if d == 0 else ("tomorrow" if d == 1 else f"in {d} days")

_NEWS_STRIP = re.compile(r'''
    \(Ordinance[^)]*\) | \(Res[^)]*\) | \(SEE\s+ATTACHED[^)]*\) |
    \bOrdinance\s+[A-Z]-?\d+\b | \bPHO-[0-9A-Za-z.\-]+ | \bZ-\d[\d\-]* |
    \bZON-?\d+ | \bGPA-?\d+ | \bDR-?\d+ | \bPL-?\d+ | \bS-\d{3,} | \bRES[ \-]?\d+ |
    \bSeries\s+\d{4} | \bAnnexation\s+\d+ | \bDistrict\s+\d+ | \bCase\s+No\.?\s*\S+ |
    \bRFP\s+\S+ | \*{2,}[^*]*\*{2,}
''', re.I | re.X)
_NEWS_BOILER = re.compile(r'''
    PUBLIC\s+HEARING\s+ITEM | ACTION\s+ITEM | INFORMATION\s+ITEM | CONSENT\s+ITEM |
    DISCUSSION(\s+AND\s+POSSIBLE\s+ACTION)?\s+ITEM |
    Hold\s+(the\s+second\s+and\s+final|a|the\s+first(\s+and\s+only)?)\s+public\s+hearing(\s+(for|on|to))? |
    second\s+and\s+final\s+reading | first\s+reading |
    Amend\s+City\s+Code | Ordinance\s+Adoption | Public\s+Hearing\s+and |
    Request\s+for\s+Award | Request\s+to\s+Withdraw | Formal\s+Action |
    Modification\s+of\s+Stipulation\s+Request\s+for\s+Ratification\s+of |
    Issuance\s+of\s+a | Construction\s+Administration\s+and\s+Observation\s+Services |
    Remove\s*/\s*Replace\s+Zoning\s+District | PCD\s+Major\s+Amendment | Series\b
''', re.I | re.X)

def news_url(r):
    """A pre-scoped Google News search for THIS item: distinctive title terms with
    case numbers and agenda boilerplate stripped, plus city + Arizona to keep results
    from drifting to the other Glendale / Peoria / etc. We link to a search rather than
    asserting a specific article, because local coverage is sparse and auto-matching
    keylessly is unreliable."""
    t = r.get("title", "") or ""
    t = re.sub(r'^\s*(?:[0-9]{1,3}|[A-Za-z])[.\)]\s+', '', t)   # leading "2." / "F."
    t = re.sub(r'^\s*(?:[0-9]{1,3}|[A-Za-z])[.\)]\s+', '', t)   # a second one if present
    t = _NEWS_STRIP.sub(" ", t)
    t = _NEWS_BOILER.sub(" ", t)
    t = re.sub(r'[\-–—:;()/,]+', " ", t)
    t = re.sub(r'\s+', " ", t).strip()
    t = " ".join(t.split()[:10])
    q = f'{t} {r.get("city","")} Arizona'.strip()
    return "https://www.google.com/search?tbm=nws&q=" + urllib.parse.quote(q)

