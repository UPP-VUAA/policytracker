_TOPIC_WHY = {
    "Housing": "it affects what housing can be built or where",
    "Heat": "it touches shade, trees, or heat-mitigation policy",
    "Transit": "it relates to transit, light rail, or bus service",
    "Walkability": "it affects walkability, biking, or street safety",
}
_SUBJ_TRAIL = re.compile(r'\(Ordinance[^)]*\)|\(Res[^)]*\)|[-–—]\s*District\s+\d+\s*$', re.I)

def _clean_subject(title):
    t = title or ""
    t = re.sub(r'^\s*\((?:CONTINUED|CONT\.?|DEFERRED)[^)]*\)\s*[-–—]?\s*', '', t, flags=re.I)
    t = re.sub(r'^\s*(?:[0-9]{1,3}|[A-Za-z])[.\)]\s+', '', t)
    t = re.sub(r'^\s*(?:[0-9]{1,3}|[A-Za-z])[.\)]\s+', '', t)
    t = _SUBJ_TRAIL.sub('', t)
    t = re.sub(r'^Public Hearing\s*[-–—:]\s*', '', t, flags=re.I)
    t = re.sub(r'^Amend City Code\s*[-–—]\s*Ordinance Adoption\s*[-–—]\s*', '', t, flags=re.I)
    t = re.sub(r'^Public Hearing and Ordinance Adoption\s*[-–—]\s*', '', t, flags=re.I)
    t = re.sub(r'^Remove\s*/\s*Replace Zoning District\s*[-–—]\s*', '', t, flags=re.I)
    t = re.sub(r'^Rezoning Application\s+\S+\s*[-–—]\s*', '', t, flags=re.I)
    t = re.sub(r'^[A-Z]{2,4}-?\d[\d\-]*,?\s+', '', t)   # leading bare case id e.g. "CUP26-05,"
    t = re.sub(r'\s+', ' ', t).strip(' -–—')
    return t

def _trunc(s, n):
    s = s.strip()
    if len(s) <= n:
        return s
    cut = s[:n].rsplit(' ', 1)[0].rstrip(' ,;:-–—')
    cut = re.sub(r'\s+(and|or|the|to|of|from|in|on|for|a|an|with|that)$', '', cut, flags=re.I)
    return cut + '…'

def summarize(r):
    """Plain-language gloss built from the item's structured fields — no LLM, so it works
    on the static deployed site and never breaks the run."""
    kind = classify_kind(r)
    city = r.get("city", "")
    title = r.get("title", "") or ""
    dm = re.search(r'District\s+(\d+)', title)
    district = ""
    if dm:
        district = f", Council District {dm.group(1)}" if city == "Phoenix" else f", District {dm.group(1)}"
    lead = f"{_KIND_PLAIN.get(kind, 'An agenda item')} in {city}{district}."
    subj = _clean_subject(title)
    sj = _trunc(subj, 170)
    loc = f" Specifically: {sj}{'' if sj.endswith('…') else '.'}" if subj and len(subj) > 6 else ""
    ad, ag, sr = r.get("_action_days"), r.get("agenda", ""), status_rank(r.get("status", ""))
    if ad is not None:
        st = f" A hearing is scheduled for {ag} ({_when_label(ad)})."
    elif sr == 3:
        st = " It has been adopted or approved."
    elif sr == -1:
        st = " It failed, was denied, or was withdrawn."
    elif sr == 2:
        st = f" It was heard on {ag}." if ag else " It has been heard."
    elif ag:
        st = f" It appears on the {ag} agenda."
    else:
        st = ""
    topics = r.get("topics", [])
    why = ""
    if topics:
        reasons = "; ".join(_TOPIC_WHY[t] for t in topics if t in _TOPIC_WHY)
        why = f" Tracked under {', '.join(topics)} because {reasons}."
    refs = []
    if r.get("file"):
        refs.append(f"case {r['file']}")
    om = re.search(r'Ordinance\s+([A-Z]-?\d+)', title)
    if om:
        refs.append(f"Ordinance {om.group(1)}")
    ref = f" ({'; '.join(refs)})." if refs else ""
    return (lead + loc + st + why + ref).strip()

def _fmt_date(d):
    try:
        return dt.datetime.strptime(str(d)[:10], "%Y-%m-%d").strftime("%b %-d, %Y")
    except Exception:
        return d or ""

def item_html(r):
    kind = classify_kind(r)
    topic0 = (r["topics"][0].lower() if r.get("topics") else "")
    dotcls = f"dot-{topic0}" if topic0 in ("housing", "transit", "walkability", "heat") else ""
    if r["agenda"]:      dlabel = "Agenda " + _fmt_date(r["agenda"])
    elif r["enacted"]:   dlabel = "Enacted " + _fmt_date(r["enacted"])
    elif r["intro"]:     dlabel = "Introduced " + _fmt_date(r["intro"])
    else:                dlabel = ""
    chips = f'<span class="ot ot-kind">{esc(kind)}</span>' + "".join(
        f'<span class="ot ot-{t.lower()}">{t}</span>' for t in r["topics"])
    fileno = f'<span class="file">{esc(r["file"])}</span>' if r["file"] else ""
    status = f'<span class="status {status_class(r["status"])}">{esc(r["status"])}</span>' if r["status"] else ""
    flags = ""
    if r.get("_new"):
        flags += '<span class="inew">● New</span>'
    if r.get("_moved") in ("adopted", "failed", "advanced"):
        lbl = {"adopted": "↑ Adopted", "failed": "✕ Failed", "advanced": "↑ Advanced"}[r["_moved"]]
        flags += f'<span class="imoved im-{r["_moved"]}">{lbl}</span>'
    ad = r.get("_action_days")
    if ad is not None:
        flags += f'<span class="iact">◷ Hearing {_when_label(ad)}</span>'
    headline = esc(_clean_subject(r["title"]) or r["title"])
    dek = esc(summarize(r))
    topics_attr = " ".join(t.lower() for t in r["topics"])
    search_attr = esc(" ".join(filter(None, [r["title"], r["file"], r["type"], r["city"]])).lower())
    dspan = f'<span class="idate">{esc(dlabel)}</span>' if dlabel else ""
    return f"""<article class="item" data-uid="{r.get('_uid','')}" data-city="{esc(r['city'])}" data-kind="{esc(kind)}" data-topics="{esc(topics_attr)}" data-search="{search_attr}">
  <div class="imeta"><span class="city"><i class="dot {dotcls}"></i>{esc(r['city'])}</span>{dspan}{fileno}{flags}{status}</div>
  <a class="ititle" href="{esc(r['url'])}" target="_blank" rel="noopener">{headline}</a>
  <p class="idek">{dek}</p>
  <div class="ochips">{chips}<a class="inews" href="{news_url(r)}" target="_blank" rel="noopener" title="Search news coverage for this item">News ↗</a></div>
</article>"""

