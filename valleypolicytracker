def render_digest(rows, cutoff):
    now = dt.datetime.now(PHX)
    lines = [f"VALLEY URBAN ACTION ALLIANCE / URBAN PHOENIX PROJECT — REGIONAL POLICY & ORDINANCE TRACKER",
             f"Generated {now.strftime('%Y-%m-%d %H:%M %Z')} | window {WINDOW_DAYS}d | {len(rows)} items\n"]
    by_topic = {t: [] for t in TOPIC_ORDER}
    for r in rows:
        for t in r["topics"]:
            by_topic[t].append(r)
    for t in TOPIC_ORDER:
        lines.append(f"\n=== {t.upper()} ({len(by_topic[t])}) ===")
        for r in by_topic[t][:40]:
            st = f" [{r['status']}]" if r["status"] else ""
            lines.append(f"  {r['city']} {r['file']}{st}: {r['title'][:90]}")
            lines.append(f"     {r['url']}")
    return "\n".join(lines)

