        ["density bonus", "inclusionary", "affordable housing incentive", "height bonus",
         "bonus density", "affordability overlay"]),
}
# Operational / site-specific kinds are never "reforms" — excluding them keeps
# procurement contracts and one-off use permits from faking cross-city signal.
_REFORM_EXCLUDE_KINDS = {"Contract/IGA", "Use permit", "ROW/Easement", "Variance", "Plat/Subdiv"}

def reform_themes(r):
    if classify_kind(r) in _REFORM_EXCLUDE_KINDS:
        return []
    t = (r.get("title", "") + " " + r.get("type", "")).lower()
    return [k for k, (lbl, topic, kws) in REFORMS.items() if any(kw in t for kw in kws)]

def _reform_bucket(status):
    s = (status or "").lower()
    if any(w in s for w in ("adopt", "approv", "enact", "passed")): return "Adopted"
    if any(w in s for w in ("fail", "denied", "withdraw", "reject")): return "Failed"
    if any(w in s for w in ("heard", "continued", "introduce")):     return "Heard"
    return "Pending"

def build_precedent(rows):
    """Cluster reforms appearing in 2+ cities; flag 'leverage' cases where a peer
    has adopted while another city's version is still pending/heard."""
    buckets = {}
    for r in rows:
        for k in reform_themes(r):
            buckets.setdefault(k, []).append(r)
    clusters = []
    for k, items in buckets.items():
        cities = {r["city"] for r in items}
        if len(cities) < 2:
            continue
        by = {}
        for r in items:
            by.setdefault(_reform_bucket(r["status"]), {}).setdefault(r["city"], []).append(r)
        leverage = ("Adopted" in by) and ("Pending" in by or "Heard" in by)
        clusters.append({"key": k, "label": REFORMS[k][0], "topic": REFORMS[k][1],
                         "items": items, "n_cities": len(cities), "by": by, "leverage": leverage})
    clusters.sort(key=lambda c: (not c["leverage"], -c["n_cities"], -len(c["items"])))
    return clusters

_PBUCKETS = [("Adopted", "pb-adopt", "✓"), ("Heard", "pb-heard", "◷"),
             ("Pending", "pb-pend", "◷"), ("Failed", "pb-fail", "✕")]

def render_precedent(clusters):
    if not clusters:
        return ""
    cards = ""
    for c in clusters:
        lev = '<span class="plev">precedent set</span>' if c["leverage"] else ""
        rows_html = ""
        for name, cls, glyph in _PBUCKETS:
            grp = c["by"].get(name)
            if not grp:
                continue
            cl = ", ".join(
                (f'{esc(ct)} <span class="pn">{len(its)}</span>' if len(its) > 1 else esc(ct))
                for ct, its in sorted(grp.items(), key=lambda x: -len(x[1])))
            rows_html += (f'<div class="prow"><span class="pb {cls}">{glyph} {name}</span>'
                          f'<span class="pcities">{cl}</span></div>')
        li = ""
        for name, _, _ in _PBUCKETS:
            grp = c["by"].get(name)
            if not grp:
                continue
            for ct, its in sorted(grp.items()):
                for r in its:
                    li += (f'<li><span class="pic">{esc(ct)}</span>'
                           f'<a href="{esc(r["url"])}" target="_blank" rel="noopener">'
                           f'{esc(_trunc(_clean_subject(r["title"]), 76))}</a> '
                           f'<span class="pis">{esc(_reform_bucket(r["status"]))}</span></li>')
        cards += (f'<div class="pcard pc-{esc(c["topic"])}">'
                  f'<div class="ptop"><span class="plabel">{esc(c["label"])}</span>'
                  f'<span class="pcount">{c["n_cities"]} cities</span>{lev}</div>'
                  f'{rows_html}'
                  f'<details class="pitems"><summary>{len(c["items"])} item(s)</summary>'
                  f'<ul>{li}</ul></details></div>')
    return (f'<section class="precedent" id="precedent">'
            f'<h3><span class="ahdr">Cross-city reform watch</span>'
            f'<span class="asub">where the same reform is moving in more than one Valley city · educational tracking</span></h3>'
            f'<div class="pgrid">{cards}</div></section>')

def render_html(rows, cutoff, events_log=None, action_items=None, first_run=False, archive_n=0, map_payload=None, map_placed=0):
    now = dt.datetime.now(PHX)
    for i, r in enumerate(rows):
        r["_uid"] = i
    by_topic = {t: [] for t in TOPIC_ORDER}
    for r in rows:
        for t in r["topics"]:
            by_topic[t].append(r)
    counts = {t: len(by_topic[t]) for t in TOPIC_ORDER}
    cities_live = sorted({r["city"] for r in rows})

    summary = "".join(
        f'<a class="sum sum-{t.lower()}" href="#{t.lower()}"><span class="n" data-tile="{t}">{counts[t]}</span>'
        f'<span class="l">{t}</span></a>' for t in TOPIC_ORDER)

    # ---- Filter bar (City + Type), populated only with values present ----
    city_counts = Counter(r["city"] for r in rows)
    cities_present = [c for c, _ in city_counts.most_common()]
    kind_counts = Counter(classify_kind(r) for r in rows)
    kind_pref = [k for k, _ in _KIND_RULES] + ["Other"]
    kinds_present = sorted(kind_counts, key=lambda k: kind_pref.index(k) if k in kind_pref else 99)
    city_chips = "".join(
        f'<button class="chipf" data-fcity="{esc(c)}">{esc(c)}<i>{city_counts[c]}</i></button>'
        for c in cities_present)
    kind_chips = "".join(
        f'<button class="chipf" data-fkind="{esc(k)}">{esc(k)}<i>{kind_counts[k]}</i></button>'
        for k in kinds_present)
    topic_chips = "".join(
        f'<button class="chipf chipf-{t.lower()}" data-ftopic="{t.lower()}">{t}<i>{counts[t]}</i></button>'
        for t in TOPIC_ORDER)
    total = len(rows)
    filterbar = f"""<div class="filters" id="filters">
  <div class="frow fsearchrow">
    <span class="flab">Find</span>
    <input id="fsearch" class="fsearch" type="text" autocomplete="off" spellcheck="false"
       placeholder="Search title, case number, or keyword…">
    <button class="fx" id="fsearchx" title="Clear search" aria-label="Clear search">×</button>
