# COLLECT
# ----------------------------------------------------------------------------
def collect():
    cutoff = (dt.datetime.now(PHX) - dt.timedelta(days=WINDOW_DAYS)).date()
    print(f"Collecting items modified since {cutoff} ({WINDOW_DAYS}-day window)...")
    rows = []
    for slug, name, county in LEGISTAR_CITIES:
        rows.extend(fetch_legistar(slug, name, county, cutoff))
    for slug, name, county, vids in GRANICUS_CITIES:
        rows.extend(fetch_granicus(slug, name, county, vids, cutoff))
    for pid, name, county in DESTINY_CITIES:
        rows.extend(fetch_destiny(pid, name, county, cutoff))
    # sort: newest activity first
    rows.sort(key=lambda r: (r["last_modified"], r["file"]), reverse=True)
    return rows, cutoff

# ----------------------------------------------------------------------------
# CHANGE DETECTION  (run-to-run diff -> "What moved" + "Act now")
# ----------------------------------------------------------------------------
def item_key(r):
    """Stable identity across runs. Legistar items have a reliable file number;
    agenda items fall back to a hash of their normalized title."""
    c = (r.get("city") or "").lower()
    f = (r.get("file") or "").strip().lower()
    if f:
        return f"{c}|{f}"
    t = re.sub(r'^\s*[\dA-Za-z]{1,3}[.\)]\s+', '', r.get("title", "") or "")
    t = re.sub(r'\s+', ' ', t).strip().lower()[:140]
    return f"{c}|t:{hashlib.md5(t.encode()).hexdigest()[:10]}"

def _agenda_iso(r):
    ag = (r.get("agenda") or "").strip()
    try:
        dt.date.fromisoformat(ag); return ag
    except ValueError:
        return None

def status_rank(s):
    """Rough pipeline stage so we can tell which way an item moved."""
    s = (s or "").lower()
    if any(w in s for w in ["adopt", "approv", "enact", "pass", "grant"]): return 3
    if any(w in s for w in ["fail", "denied", "withdraw", "reject", "remov"]): return -1
    if any(w in s for w in ["heard", "hearing", "committee", "second read"]): return 2
    if any(w in s for w in ["upcoming", "agenda", "introduc", "filed", "pending", "first read", "scheduled"]): return 1
    return 0

def load_state():
    try:
        d = json.loads(STATE.read_text(encoding="utf-8"))
        if isinstance(d, dict) and "items" in d:
            return d
    except Exception:
        pass
    return {"items": {}, "events": []}

def save_state(state):
    try:
        STATE.write_text(json.dumps(state, indent=1), encoding="utf-8")
    except Exception as e:
        print(f"   ! could not write state: {type(e).__name__}")

def _mkev(kind, r, today_s, frm="", to=""):
    return {"date": today_s, "kind": kind, "city": r["city"], "title": r["title"],
            "url": r["url"], "file": r.get("file", ""), "from": frm, "to": to,
            "hearing": _agenda_iso(r) or "", "topics": r.get("topics", [])}

def compute_changes(rows, state, today):
    """Annotates each row with _action_days / _new / _moved, and returns the list
    of change-events generated on THIS run plus the refreshed per-item ledger."""
    today_s = today.isoformat()
    prev_items = state.get("items", {})
    first_run = len(prev_items) == 0
    items, new_events, seen = {}, [], set()

    for r in rows:
        k = item_key(r); seen.add(k)
        st = (r.get("status") or "").strip()
        hd = _agenda_iso(r)
        # action window (upcoming hearing within N days)
        r["_action_days"] = None
        if hd:
            dd = (dt.date.fromisoformat(hd) - today).days
            if 0 <= dd <= ACTION_WINDOW_DAYS:
                r["_action_days"] = dd
        r["_new"] = False; r["_moved"] = ""; r["_movefrom"] = ""; r["_moveto"] = ""
        prev = prev_items.get(k)

        if prev is None:
            items[k] = {"first_seen": today_s, "last_seen": today_s, "status": st,
                        "hearing": hd, "city": r["city"], "title": r["title"], "url": r["url"]}
            if not first_run:
                r["_new"] = True
                new_events.append(_mkev("new", r, today_s))
        else:
            rec = dict(prev); rec["last_seen"] = today_s
            rec["title"] = r["title"]; rec["url"] = r["url"]
            prev_status = prev.get("status", "")
            if st and st != prev_status:
                rec["status"] = st
                pr, cr = status_rank(prev_status), status_rank(st)
                r["_movefrom"] = prev_status; r["_moveto"] = st
                if cr == 3:
                    r["_moved"] = "adopted"; new_events.append(_mkev("adopted", r, today_s, prev_status, st))
                elif cr == -1:
                    r["_moved"] = "failed"; new_events.append(_mkev("failed", r, today_s, prev_status, st))
                elif cr > pr:
                    r["_moved"] = "advanced"; new_events.append(_mkev("advanced", r, today_s, prev_status, st))
            prev_h = prev.get("hearing"); rec["hearing"] = hd
            if hd and hd != prev_h and (dt.date.fromisoformat(hd) - today).days >= 0:
                new_events.append(_mkev("scheduled", r, today_s))
            items[k] = rec

    # keep ledger entries for items that dropped off, for up to 30 days
    for k, v in prev_items.items():
        if k in seen:
            continue
        try:
            ls = dt.date.fromisoformat(v.get("last_seen", today_s))
        except ValueError:
            ls = today
        if (today - ls).days <= 30:
            items[k] = v

    # merge + prune the event log (keep a little beyond the display window)
    log = (state.get("events", []) + new_events)
    keep_after = (today - dt.timedelta(days=CHANGELOG_DAYS + 7)).isoformat()
    log = [e for e in log if e.get("date", "") >= keep_after]
    new_state = {"updated": today_s, "items": items, "events": log}
    return new_events, new_state, first_run


