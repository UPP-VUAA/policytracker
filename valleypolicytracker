_EVENT_GROUPS = [
    ("adopted",   "Adopted / passed", "mg-pass"),
    ("failed",    "Failed / withdrawn", "mg-fail"),
    ("advanced",  "Advanced (heard or progressed)", "mg-adv"),
    ("new",       "Newly appeared", "mg-new"),
