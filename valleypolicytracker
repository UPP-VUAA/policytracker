<script>
(function(){{
  var TOTAL = {len(rows)};
  var TOPICS = ["housing","heat","transit","walkability"];
  var selCity = new Set(), selKind = new Set(), selTopic = new Set();
  var term = "";
  function cap(s){{ return s.charAt(0).toUpperCase()+s.slice(1); }}

  // Deduped record list (one per distinct item), used for faceted chip counts.
  var ITEMS = [];
  (function(){{
    var seen = {{}};
    document.querySelectorAll('.item').forEach(function(it){{
      var u = it.getAttribute('data-uid');
      if(seen[u]) return; seen[u] = 1;
      ITEMS.push({{
        city: it.getAttribute('data-city'),
        kind: it.getAttribute('data-kind'),
        topics: (it.getAttribute('data-topics') || '').split(' ').filter(Boolean),
        search: it.getAttribute('data-search') || ''
      }});
    }});
  }})();

  function kwOk(r){{
    if(!term) return true;
    return term.split(/\\s+/).every(function(w){{ return !w || r.search.indexOf(w) !== -1; }});
  }}
  function cityOk(r){{ return selCity.size===0 || selCity.has(r.city); }}
  function kindOk(r){{ return selKind.size===0 || selKind.has(r.kind); }}
  function topicOk(r){{ return selTopic.size===0 || r.topics.some(function(t){{ return selTopic.has(t); }}); }}

  // Counts = how many items in the CURRENT filtered result fall in each bucket.
  // Every active filter (including the chip's own category) is applied, so the
  // numbers in every row react to every selection. Selecting Phoenix drops the
  // other City chips to 0, and the Type/Topic rows show Phoenix's breakdown.
  function inResult(r){{ return cityOk(r) && kindOk(r) && topicOk(r) && kwOk(r); }}
  function countCity(c){{ var n=0; ITEMS.forEach(function(r){{ if(r.city===c && inResult(r)) n++; }}); return n; }}
  function countKind(k){{ var n=0; ITEMS.forEach(function(r){{ if(r.kind===k && inResult(r)) n++; }}); return n; }}
  function countTopic(t){{ var n=0; ITEMS.forEach(function(r){{ if(r.topics.indexOf(t)!==-1 && inResult(r)) n++; }}); return n; }}
  function setCounts(attr, fn){{
    document.querySelectorAll('['+attr+']').forEach(function(b){{
      var v = b.getAttribute(attr), n = fn(v), i = b.querySelector('i');
      if(i) i.textContent = n;
      b.classList.toggle('zero', n===0 && !b.classList.contains('on'));
    }});
  }}

  function matchKW(it){{
    if(!term) return true;
    var hay = it.getAttribute('data-search') || "";
    return term.split(/\\s+/).every(function(w){{ return !w || hay.indexOf(w) !== -1; }});
  }}
  function matchesCT(it){{   // city + type + keyword (topic handled per section)
    var c = it.getAttribute('data-city'), k = it.getAttribute('data-kind');
    return (selCity.size===0 || selCity.has(c))
        && (selKind.size===0 || selKind.has(k))
        && matchKW(it);
  }}
  function apply(){{
    var seen = {{}};
    TOPICS.forEach(function(t){{
      var sec = document.getElementById(t);
      if(!sec) return;
      var topicOn = (selTopic.size===0 || selTopic.has(t));
      var n = 0;
      sec.querySelectorAll('.item').forEach(function(it){{
        var ok = topicOn && matchesCT(it);
        it.classList.toggle('hide', !ok);
        if(ok){{ n++; seen[it.getAttribute('data-uid')] = 1; }}
      }});
      var badge = sec.querySelector('[data-sec]'); if(badge) badge.textContent = n;
      var tile = document.querySelector('[data-tile="'+cap(t)+'"]'); if(tile) tile.textContent = n;
      sec.classList.toggle('sechide', n===0);
    }});
    var vis = Object.keys(seen).length;
    document.getElementById('fcount').innerHTML = 'Showing <b>'+vis+'</b> of '+TOTAL;
    var anyOn = selCity.size>0 || selKind.size>0 || selTopic.size>0 || term.length>0;
    document.getElementById('filters').classList.toggle('active', anyOn);
    var nh = document.getElementById('fnohit'); if(nh) nh.classList.toggle('show', vis===0);
    setCounts('data-fcity', countCity);
    setCounts('data-fkind', countKind);
    setCounts('data-ftopic', countTopic);
  }}
  function bind(attr, set){{
    document.querySelectorAll('['+attr+']').forEach(function(b){{
      b.addEventListener('click', function(){{
        var v = b.getAttribute(attr);
        if(set.has(v)){{ set.delete(v); b.classList.remove('on'); }}
        else {{ set.add(v); b.classList.add('on'); }}
        apply();
      }});
    }});
