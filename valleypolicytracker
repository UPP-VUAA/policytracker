  <div class="frow"><span class="flab">City</span><div class="fchips">{city_chips}</div></div>
  <div class="frow"><span class="flab">Type</span><div class="fchips">{kind_chips}</div></div>
  <div class="frow ftools">
    <button class="fclear" id="fclear">Reset filters</button>
    <span class="fcount" id="fcount">Showing <b>{total}</b> of {total}</span>
  </div>
</div>"""

    sections = ""
    for t in TOPIC_ORDER:
        # float items with an upcoming hearing to the top (soonest first),
        # otherwise preserve the existing newest-first order
        items = sorted(by_topic[t], key=lambda r: (
            0 if r.get("_action_days") is not None else 1,
            r.get("_action_days") if r.get("_action_days") is not None else 0))
        body = "".join(item_html(r) for r in items) if items else \
            '<p class="empty">No matching items in this window. An empty list is a clean signal, not a gap.</p>'
        sections += f"""<section class="topic" id="{t.lower()}">
  <header class="thead th-{t.lower()}">
    <h2>{t}</h2><span class="tcount" data-sec="{t}">{len(items)}</span>
    <span class="tblurb">{TOPIC_BLURB[t]}</span>
  </header>
  <div class="items">{body}</div>
</section>"""

    cov_live = "".join(
        f'<li class="cov ok"><b>{esc(n)}</b><span>{esc(c)} · live</span></li>'
        for _, n, c in LEGISTAR_CITIES) + "".join(
        f'<li class="cov ok"><b>{esc(n)}</b><span>{esc(c)} · live (agendas)</span></li>'
        for _, n, c, _v in GRANICUS_CITIES) + "".join(
        f'<li class="cov ok"><b>{esc(n)}</b><span>{esc(c)} · live (agendas)</span></li>'
        for _, n, c in DESTINY_CITIES)
    cov_next = "".join(
        f'<li class="cov next"><b>{esc(n)}</b><span>{esc(p)}</span></li>'
        for n, p, _ in ROADMAP)

    map_block = ""
    if map_payload:
