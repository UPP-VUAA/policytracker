def render_moved(events_log, first_run, today):
    """Retrospective panel: change-events from the last CHANGELOG_DAYS days."""
    cutoff = (today - dt.timedelta(days=CHANGELOG_DAYS)).isoformat()
    recent = [e for e in events_log if e.get("date", "") >= cutoff]
    head = (f'<h3><span class="ahdr">What moved</span>'
            f'<span class="asub">last {CHANGELOG_DAYS} days</span></h3>'
            f'<p class="pdesc">Every night this tracker compares the latest agenda and legislative '
            f'data against the previous run and records what changed. "What moved" lists those changes '
            f'from the last {CHANGELOG_DAYS} days — items that newly appeared, advanced toward a decision '
            f'(heard or progressed), were adopted or failed, or were newly scheduled for a hearing. '
            f'Anything not listed here is unchanged since the last run.</p>')
    if first_run:
        return (f'<section class="moved" id="moved">{head}<p class="movedempty">Baseline established '
                f'today — changes will start showing here on the next daily run.</p></section>')
    if not recent:
        return (f'<section class="moved" id="moved">{head}<p class="movedempty">No tracked changes in the '
                f'last {CHANGELOG_DAYS} days.</p></section>')
    by_kind = {}
    for e in recent:
        by_kind.setdefault(e.get("kind"), []).append(e)
    groups = ""
    for kind, label, cls in _EVENT_GROUPS:
        items = by_kind.get(kind, [])
        if not items:
            continue
        items.sort(key=lambda e: e.get("date", ""), reverse=True)
        lis = ""
        for e in items[:8]:
            extra = ""
            if kind in ("adopted", "failed", "advanced") and e.get("from") and e.get("to"):
                extra = f' <span class="mdelta">{esc(_short(e["from"],28))} → {esc(_short(e["to"],28))}</span>'
            elif kind == "scheduled" and e.get("hearing"):
                extra = f' <span class="mdelta">hearing {esc(e["hearing"])}</span>'
            fileno = f'<span class="mfile">{esc(e["file"])}</span>' if e.get("file") else ""
            lis += (f'<li><a href="{esc(e["url"])}" target="_blank" rel="noopener">'
                    f'<span class="mcity">{esc(e["city"])}</span>{fileno}'
                    f'<span class="mtitle">{esc(_short(e["title"]))}</span>{extra}'
                    f'<span class="mdate">{esc(e["date"])}</span></a></li>')
        more = f'<li class="moremsg">+{len(items)-8} more</li>' if len(items) > 12 else ""
        groups += f'<div class="mgroup"><h4 class="{cls}">{label}<b>{len(items)}</b></h4><ul>{lis}{more}</ul></div>'
    return f'<section class="moved" id="moved">{head}<div class="mgrid">{groups}</div></section>'


