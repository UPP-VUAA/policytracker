def _svg_hbar(pairs, color="#040404", w=560, rowh=27, pad=10, label_w=150, val_w=46, maxv=None):
    pairs = list(pairs)
    if not pairs:
        return '<p class="empty">No data in the current window.</p>'
    maxv = maxv or max((v for _, v in pairs), default=1) or 1
    barw = w - label_w - val_w - pad * 2
    h = pad * 2 + rowh * len(pairs)
    out = [f'<svg viewBox="0 0 {w} {h}" class="svgchart" preserveAspectRatio="xMinYMin meet" role="img">']
    for i, (lab, v) in enumerate(pairs):
        cy = pad + i * rowh + rowh / 2
        bw = max(2, barw * (v / maxv))
        col = color(lab) if callable(color) else color
        out.append(f'<text x="{label_w-7}" y="{cy}" text-anchor="end" dominant-baseline="central" class="svglab">{esc(str(lab))}</text>')
        out.append(f'<rect x="{label_w}" y="{cy-rowh/2+4.5}" width="{bw:.1f}" height="{rowh-9}" fill="{col}" rx="1.5"/>')
        out.append(f'<text x="{label_w+bw+6:.1f}" y="{cy}" dominant-baseline="central" class="svgval">{v}</text>')
    out.append('</svg>')
    return "".join(out)

def _best_month(r):
    for f in ("enacted", "agenda", "intro", "last_modified"):
        v = (r.get(f) or "").strip()
        try:
            return dt.date.fromisoformat(v).strftime("%Y-%m")
        except ValueError:
            continue
    return None

_STATUS_BUCKETS = [
    ("Pending / scheduled", 1, "#040404"),
    ("Heard", 2, "#8a6d00"),
    ("Adopted / passed", 3, "#1c6b2e"),
    ("Failed / withdrawn", -1, "#8a1c1c"),
    ("In process / other", 0, "#9a9a8e"),
]

def render_trends(rows, archive_n=0):
    # status buckets + adoption rate
    rank = {0: 0, 1: 0, 2: 0, 3: 0, -1: 0}
    for r in rows:
        rank[status_rank(r.get("status", ""))] = rank.get(status_rank(r.get("status", "")), 0) + 1
    status_pairs = [(lbl, rank.get(rk, 0)) for lbl, rk, _ in _STATUS_BUCKETS if rank.get(rk, 0)]
    status_col = {lbl: c for lbl, _, c in _STATUS_BUCKETS}
    decided = rank.get(3, 0) + rank.get(-1, 0)
    adopt_rate = f"{round(100*rank.get(3,0)/decided)}%" if decided else "—"

    # activity by month (chronological) — cap to recent months; older dates are
    # stale enacted/intro stamps on items only recently modified, not window activity
    months = Counter(m for m in (_best_month(r) for r in rows) if m)
    month_pairs = [(m, months[m]) for m in sorted(months)][-14:]

    # most active cities
    city_pairs = Counter(r["city"] for r in rows).most_common()

    # Phoenix rezoning by council district
    dist = Counter()
    for r in rows:
        if r["city"] == "Phoenix" and classify_kind(r) == "Rezoning":
            m = re.search(r'District\s+(\d+)', r.get("title", "") or "")
            if m:
                dist[int(m.group(1))] += 1
    dist_pairs = [(f"District {d}", dist[d]) for d in sorted(dist)]

    archive_note = (f' · accumulating a daily snapshot archive (<b>{archive_n}</b> run(s) recorded so far) '
                    f'for true month-over-month trend lines') if archive_n else ""
    return f"""<section class="numbers" id="numbers">
  <header class="nhead"><h2>By the numbers</h2>
    <span class="nblurb">A live read on the {WINDOW_DAYS}-day window across every tracked city{archive_note}.</span>
  </header>
  <div class="ngrid">
    <div class="ncard ncard-stat">
      <div class="bignum">{len(rows)}</div><div class="biglab">items tracked right now</div>
      <div class="substat"><b>{adopt_rate}</b> of decided items were adopted <span>({rank.get(3,0)} adopted · {rank.get(-1,0)} failed/withdrawn)</span></div>
    </div>
    <div class="ncard"><h3>Where items stand</h3>{_svg_hbar(status_pairs, color=lambda l: status_col.get(l,"#040404"))}</div>
    <div class="ncard ncard-wide"><h3>Activity by month <span>(by most recent action date)</span></h3>{_svg_hbar(month_pairs, color="#040404", label_w=78)}</div>
    <div class="ncard"><h3>Most active cities</h3>{_svg_hbar(city_pairs, color="#040404")}</div>
    <div class="ncard"><h3>Phoenix rezonings by council district</h3>{_svg_hbar(dist_pairs, color="#F6DC31", label_w=88) if dist_pairs else '<p class="empty">No districted Phoenix rezonings in window.</p>'}</div>
  </div>
</section>"""

def render_actnow(action_items):
