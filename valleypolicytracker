GEOCACHE = Path(__file__).parent / "geocache.json"
DISTCACHE = Path(__file__).parent / "districts.geojson"
PHX_DISTRICTS_URL = ("https://maps.phoenix.gov/pub/rest/services/Public/Council_Districts/"
                     "MapServer/0/query?where=1%3D1&outFields=DISTRICT,REP_NAME,REP_URL&"
                     "returnGeometry=true&f=geojson&outSR=4326")
_ST = r'(?:Avenue|Ave|Street|St|Drive|Dr|Road|Rd|Boulevard|Blvd|Lane|Ln|Way|Place|Pl|Parkway|Pkwy|Circle|Trail|Tr)'
_NM = r'(?:[A-Z][a-zA-Z]+|\d{1,3}(?:st|nd|rd|th))'
_INTER_RX = re.compile(r'(' + _NM + r'(?:\s+' + _NM + r'){0,2}\s+' + _ST + r')\s*(?:and|&|/| at )\s*('
                       + _NM + r'(?:\s+' + _NM + r'){0,2}\s+' + _ST + r')', re.I)
_LEAD_JUNK = re.compile(r'^(?:the\s+)?(?:south|north)?(?:east|west)?\s*(?:corner|intersection)\s+of\s+', re.I)

def extract_intersection(title):
    m = _INTER_RX.search(title or "")
    if not m:
        return None
    a = _LEAD_JUNK.sub("", m.group(1)).strip()
    b = m.group(2).strip()
    return f"{a} and {b}"

def _load_json(p, default):
    try:
        return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return default

def geocode(address, city, cache, ctx):
    """Census geocoder (keyless), cached. Returns [lng,lat] or None."""
    key = f"{address}, {city}, AZ"
    if key in cache:
        return cache[key]
    q = urllib.parse.urlencode({"address": key, "benchmark": "Public_AR_Current", "format": "json"})
    url = "https://geocoding.geo.census.gov/geocoder/locations/onelineaddress?" + q
    val = None
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "UPP-policy-tracker/1.0"})
        d = json.loads(urllib.request.urlopen(req, timeout=20, context=ctx).read().decode("utf-8", "ignore"))
        ms = d["result"]["addressMatches"]
        if ms:
            c = ms[0]["coordinates"]
            val = [round(c["x"], 6), round(c["y"], 6)]
    except Exception:
        val = None
    cache[key] = val
    return val

def _round_coords(x):
    if isinstance(x, (list, tuple)):
        return [_round_coords(i) for i in x]
    if isinstance(x, float):
        return round(x, 4)
    return x

def build_map_payload(rows):
    """Build the JSON payload shared by the embedded dashboard map and the
    standalone map page: slimmed district polygons + per-district counts + pins."""
    ctx = ssl.create_default_context(); ctx.check_hostname = False; ctx.verify_mode = ssl.CERT_NONE
    districts = None
    try:
        req = urllib.request.Request(PHX_DISTRICTS_URL, headers={"User-Agent": "UPP-policy-tracker/1.0"})
        districts = json.loads(urllib.request.urlopen(req, timeout=30, context=ctx).read().decode("utf-8", "ignore"))
        if districts.get("features"):
            DISTCACHE.write_text(json.dumps(districts), encoding="utf-8")
    except Exception:
        districts = _load_json(DISTCACHE, None)
    if not districts or not districts.get("features"):
        districts = {"type": "FeatureCollection", "features": []}
    # slim: keep only the properties the popup uses; round coords to ~11 m
    feats = []
    for f in districts.get("features", []):
        p = f.get("properties", {}) or {}
        g = f.get("geometry", {}) or {}
        feats.append({"type": "Feature",
                      "properties": {k: p.get(k) for k in ("DISTRICT", "REP_NAME", "REP_URL")},
                      "geometry": {"type": g.get("type"),
                                   "coordinates": _round_coords(g.get("coordinates", []))}})
    districts = {"type": "FeatureCollection", "features": feats}

    dd = {}
    for r in rows:
        if r["city"] != "Phoenix":
            continue
        m = re.search(r'District\s+(\d+)', r.get("title", "") or "")
        if not m:
            continue
        d = m.group(1)
        e = dd.setdefault(d, {"count": 0, "Housing": 0, "Heat": 0, "Transit": 0, "Walkability": 0})
        e["count"] += 1
        for t in r["topics"]:
            e[t] = e.get(t, 0) + 1

    cache = _load_json(GEOCACHE, {})
    pins, placed = [], 0
    _TOPIC_HEX = {"Housing": "#1c6b2e", "Transit": "#3a3a8a", "Walkability": "#b3361f",
                  "Heat": "#c98a00"}
    for r in rows:
        inter = extract_intersection(r.get("title", "") or "")
        if not inter:
            continue
        try:
            ll = geocode(inter, r["city"], cache, ctx)
        except Exception:
            ll = None
        if not ll:
            continue
        placed += 1
        topic = r["topics"][0] if r["topics"] else "Housing"
        pins.append({"lat": round(ll[1], 5), "lng": round(ll[0], 5),
                     "color": _TOPIC_HEX.get(topic, "#040404"),
                     "title": r["title"][:140], "city": r["city"], "status": r.get("status", ""),
                     "topics": ", ".join(r["topics"]), "url": r["url"],
                     "summary": summarize(r)[:240], "news": news_url(r)})
    try:
        GEOCACHE.write_text(json.dumps(cache, indent=0), encoding="utf-8")
    except Exception:
        pass
    payload = json.dumps({"districts": districts, "dd": dd, "pins": pins},
                         separators=(",", ":"))
    return payload, placed, len(pins)

def write_map(rows, out_path, prebuilt=None):
    payload, placed, npins = prebuilt if prebuilt else build_map_payload(rows)
    html = _MAP_TEMPLATE.replace("/*DATA*/", payload).replace(
        "{PLACED}", str(placed)).replace("{NPINS}", str(npins)).replace(
        "{GEN}", dt.datetime.now(PHX).strftime("%Y-%m-%d %H:%M %Z"))
    out_path.write_text(html, encoding="utf-8")
    print(f"   map: {len(json.loads(payload)['districts']['features'])} districts, {placed} pins placed")

