  bind('data-fcity', selCity);
  bind('data-fkind', selKind);
  bind('data-ftopic', selTopic);
  var box = document.getElementById('fsearch');
  box.addEventListener('input', function(){{ term = box.value.trim().toLowerCase(); apply(); }});
  document.getElementById('fsearchx').addEventListener('click', function(){{
    box.value = ""; term = ""; box.focus(); apply();
  }});
  document.getElementById('fclear').addEventListener('click', function(){{
    selCity.clear(); selKind.clear(); selTopic.clear(); term = ""; box.value = "";
    document.querySelectorAll('.chipf.on').forEach(function(b){{ b.classList.remove('on'); }});
    apply();
  }});
}})();
</script>
