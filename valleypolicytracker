# ----------------------------------------------------------------------------
# TOPIC TAXONOMY  (edit freely — this is the heart of the filter)
# ----------------------------------------------------------------------------
# Matching rules (handled automatically below):
#   * a term with a space or hyphen  -> matched as a plain phrase (substring)
#   * a plain word                   -> matched at a LEFT word boundary, so
#                                        "rezon" hits rezoning/rezone, and
#                                        "tree" will NOT hit "street".
#   * terms in EXACT need both boundaries (avoids bus->business, adu->adult)
TOPICS = {
    "Housing": [
        "zoning", "rezon", "zon2", "zon1", "z-2", "land use", "general plan",
        "accessory dwelling", "middle housing", "density", "dwelling unit",
        "setback", "lot size", "subdivision", "multifamily", "multi-family",
        "duplex", "triplex", "fourplex", "residential", "mixed-use", "mixed use",
        "planned unit", "infill", "affordable", "single-stair", "single stair",
        "pad", "overlay district",
    ],
    "Heat": [
        "heat", "shade", "tree", "urban forest", "tree canopy", "canopy",
        "cool corridor", "cool pavement", "cool roof", "reflective", "landscap",
        "cooling", "xeriscap", "drought", "shade structure",
    ],
    "Transit": [
        "transit", "light rail", "streetcar", "valley metro", "mobility",
        "micromobility", "transportation", "park-and-ride", "park and ride",
        "bus", "rideshare",
    ],
    "Walkability": [
        "walkab", "pedestrian", "sidewalk", "crosswalk", "vision zero",
        "complete street", "road diet", "traffic calming", "bike lane",
        "bikeway", "bicycle", "shared use path", "multi-use path", "streetscape",
        "ada ramp",
    ],
}
EXACT = {"bus", "adu", "pad", "ada", "tree"}  # tree handled as prefix is fine; bus/pad need exact

# Pre-compile matchers
def _build_matchers(terms):
    out = []
    for t in terms:
        tl = t.lower()
        if " " in tl or "-" in tl:
            out.append(("phrase", tl))
        elif tl in EXACT:
            out.append(("re", re.compile(r"\b" + re.escape(tl) + r"s?\b")))
        else:
            out.append(("re", re.compile(r"\b" + re.escape(tl))))  # left-boundary prefix
    return out

MATCHERS = {topic: _build_matchers(terms) for topic, terms in TOPICS.items()}

def topics_for(text):
    t = text.lower()
    hits = []
    for topic, matchers in MATCHERS.items():
        for kind, m in matchers:
            if (kind == "phrase" and m in t) or (kind == "re" and m.search(t)):
                hits.append(topic)
                break
    return hits

# ----------------------------------------------------------------------------
# LEGISTAR ADAPTER
# ----------------------------------------------------------------------------
_ctx = ssl.create_default_context(); _ctx.check_hostname = False; _ctx.verify_mode = ssl.CERT_NONE

def _get_json(url, timeout=40):
    req = urllib.request.Request(url, headers={"Accept": "application/json", "User-Agent": "Mozilla/5.0"})
    with urllib.request.urlopen(req, timeout=timeout, context=_ctx) as r:
        return json.loads(r.read().decode(errors="replace"))

def _parse(dstr):
    if not dstr:
        return None
    try:
        return dt.datetime.fromisoformat(dstr.replace("Z", "")).date()
    except Exception:
        return None

def fetch_legistar(slug, name, county, cutoff, top=600):
    ob = urllib.parse.quote("MatterLastModifiedUtc desc")
    url = f"https://webapi.legistar.com/v1/{slug}/matters?$top={top}&$orderby={ob}"
    try:
        matters = _get_json(url)
    except Exception as e:
        print(f"   ! {name}: fetch failed ({type(e).__name__})")
        return []
    records = []
    for m in matters:
        last_mod = _parse(m.get("MatterLastModifiedUtc"))
        if last_mod and last_mod < cutoff:
            continue
        title = (m.get("MatterTitle") or m.get("MatterName") or "").strip()
        if not title:
            continue
        tt = topics_for(title)
        if not tt:
            continue
        mid, guid = m.get("MatterId"), m.get("MatterGuid")
        link = (f"https://{slug}.legistar.com/LegislationDetail.aspx?ID={mid}&GUID={guid}"
                if mid and guid else f"https://{slug}.legistar.com/Legislation.aspx")
        records.append({
            "city": name, "county": county, "topics": sorted(set(tt)),
            "file": m.get("MatterFile") or "", "type": m.get("MatterTypeName") or "",
            "status": m.get("MatterStatusName") or "", "title": title,
            "intro": str(_parse(m.get("MatterIntroDate")) or ""),
            "agenda": str(_parse(m.get("MatterAgendaDate")) or ""),
            "enacted": str(_parse(m.get("MatterEnactmentDate")) or ""),
            "last_modified": str(last_mod or ""),
            "url": link, "source": "Legistar",
        })
    print(f"   - {name}: {len(records)} relevant items")
    return records

# ----------------------------------------------------------------------------
# GRANICUS ADAPTER  (Tempe, Glendale — agenda HTML, no clean status API)
# ----------------------------------------------------------------------------
# Granicus is a meeting/video archive: items come from parsing each meeting's
# agenda page. There's no per-item adopted/failed status, so status is inferred
# from the meeting date (upcoming vs. already heard). Noisier than Legistar, so
# we gate out consent/minutes boilerplate and require a substantive signal.
GRAN_MAX_MEETINGS = 60       # per city, within the window
GRAN_MAX_PER_MTG  = 25

_LEGNOUNS = ["ordinance", "resolution", "public hearing", "use permit", "rezon",
    "zoning district", "variance", "subdivision", "general plan", "special permit",
    "preliminary plat", "final plat", "development plan", "abandonment",
    "text amendment", "planned area development", "map amendment", "conditional use",
    "annexation", "right-of-way", "easement", "plat", "overlay", "rezone"]
_ACTION = ["adopt", "approve", "award", "authorize", "introduce", "hold", "consider",
    "request", "amend", "appropriat", "ratif", "accept and disburse", "execute"]
_CASE_RE = re.compile(r'\b(PL\d{4,}|ZON\d{2}-\d+|Z-?\d+-\d+|ZTA\d+|GPA\d+|SUP\d+|'
    r'CUP\d{2}-\d+|VAR\d{2}-\d+|PAD\d+|ANX\d+|DR\d{2}|ZA\d+)\b', re.I)
# strip orphan tag-attribute remnants left when splitting on <tr>/<blockquote>
# (handles quoted values with spaces, e.g.  class=" top">  and  vAlign=top> )
_ATTR_JUNK = re.compile(r'^\s*(?:[\w:.-]+\s*=\s*(?:"[^"]*"|\'[^\']*\'|[^\s>]+)\s*)*>\s*')

def _clean_item(u):
    t = re.sub(r'<[^>]*>', ' ', u)
    t = html.unescape(re.sub(r'\s+', ' ', t)).strip()
    t = _ATTR_JUNK.sub('', t).lstrip('> ').strip()
    return t

def _substantive(t):
    tl = t.lower()
    return any(n in tl for n in _LEGNOUNS) or bool(_CASE_RE.search(t))

def _is_noise(t):
    tl = t.lower()
    # minutes / consent boilerplate
    if "minutes" in tl and any(w in tl for w in ["approval of", "acceptance of",
            "commission", "advisory board", "subcommittee"]) and not _CASE_RE.search(t):
        return True
    # bare board/commission/committee line with a date and no real action
    if re.search(r'\b(commission|committee|advisory board|subcommittee)\b', tl) \
            and not _substantive(t) and not any(a in tl for a in _ACTION):
        return True
    if tl.startswith(("project planner", "staff contact", "applicant:")):
        return True
    return False

def _parse_meetings(body, view_id):
    out = []
    for row in re.split(r'(?i)<tr[ >]', body):
        nm = re.search(r'headers="Name"[^>]*>([^<]+)</td>', row)
        ts = re.search(r'display:none;">(\d{10})</span>', row)
        cid = re.search(r'AgendaViewer\.php\?view_id=%d&clip_id=(\d+)' % view_id, row)
        if nm and ts and cid:
            out.append((html.unescape(nm.group(1)).strip(), int(ts.group(1)), cid.group(1)))
    return out

def _agenda_items(h):
    h = re.sub(r'<(script|style)[^>]*>.*?</\1>', ' ', h, flags=re.S | re.I)
    units = re.split(r'(?i)<tr[ >]', h)
    if len(units) < 4:
        units = re.split(r'(?i)<blockquote[ >]', h)
    items = []
    for u in units:
        t = _clean_item(u)
        if 30 <= len(t) <= 700:
            items.append(t)
    return items

def fetch_granicus(slug, name, county, view_ids, cutoff):
    cutoff_ts = dt.datetime(cutoff.year, cutoff.month, cutoff.day, tzinfo=PHX).timestamp()
    now_ts = dt.datetime.now(PHX).timestamp()
    records, seen_titles = [], set()
    for vid in view_ids:
        try:
            req = urllib.request.Request(
                f"https://{slug}.granicus.com/ViewPublisher.php?view_id={vid}",
                headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=40, context=_ctx) as r:
                body = r.read().decode(errors="replace")
        except Exception as e:
            print(f"   ! {name}: ViewPublisher failed ({type(e).__name__})")
            continue
        meetings = [m for m in _parse_meetings(body, vid) if m[1] >= cutoff_ts]
        meetings.sort(key=lambda m: m[1], reverse=True)
        for mname, ts, cid in meetings[:GRAN_MAX_MEETINGS]:
            try:
                req = urllib.request.Request(
                    f"https://{slug}.granicus.com/AgendaViewer.php?view_id={vid}&clip_id={cid}",
                    headers={"User-Agent": "Mozilla/5.0"})
                with urllib.request.urlopen(req, timeout=30, context=_ctx) as r:
                    ag = r.read().decode(errors="replace")
            except Exception:
                continue
            mdate = dt.datetime.fromtimestamp(ts, PHX).date()
            status = "On upcoming agenda" if ts > now_ts else f"Heard {mdate}"
            url = f"https://{slug}.granicus.com/AgendaViewer.php?view_id={vid}&clip_id={cid}"
            kept = 0
            for it in _agenda_items(ag):
                if kept >= GRAN_MAX_PER_MTG:
                    break
                if _is_noise(it):
                    continue
                tt = topics_for(it)
                if not tt or not (_substantive(it) or len(it) >= 60):
                    continue
                key = (slug, it[:90].lower())
                if key in seen_titles:
                    continue
                seen_titles.add(key)
                case = _CASE_RE.search(it)
                records.append({
                    "city": name, "county": county, "topics": sorted(set(tt)),
                    "file": case.group(0) if case else "",
                    "type": mname, "status": status,
                    "title": it[:240], "intro": "", "agenda": str(mdate),
                    "enacted": "", "last_modified": str(mdate),
                    "url": url, "source": "Granicus",
                })
                kept += 1
    print(f"   - {name}: {len(records)} relevant items (Granicus)")
    return records

# ----------------------------------------------------------------------------
# DESTINYHOSTED / AGENDAQUICK ADAPTER  (Glendale — Granicus GovAccess agendas)
# ----------------------------------------------------------------------------
# The base "mt=all" portal page aggregates current + upcoming + recent agendas.
# Each meeting row's <a> carries title="View Agenda for {BODY} ({MM/DD/YYYY})",
# which gives a clean body name + date and lets us drop quorum/notice rows.
# Note: this captures current/upcoming agendas (how the portal publishes), not a
# strict 90-day lookback — past meetings move to a separate minutes view.
_DESTINY_BASE = "https://destinyhosted.com"
_DESTINY_SKIP = re.compile(
    r'quorum|notice|cancel|upcoming|proclamation|minutes|workshop summary', re.I)
_DESTINY_LINK = re.compile(
    r'<a href="([^"]*dsp=ag[^"]*seq=(\d+))"[^>]*title="View Agenda for (.+?) \((\d{2}/\d{2}/\d{4})\)"')

def fetch_destiny(portal_id, name, county, cutoff):
    records, seen_titles = [], set()
    try:
        req = urllib.request.Request(
            f"{_DESTINY_BASE}/agenda_publish.cfm?mt=all&id={portal_id}",
            headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=40, context=_ctx) as r:
            body = r.read().decode(errors="replace")
    except Exception as e:
        print(f"   ! {name}: DestinyHosted portal failed ({type(e).__name__})")
        return records
    today = dt.datetime.now(PHX).date()
    seen_seq = set()
    for mobj in _DESTINY_LINK.finditer(body):
        href = mobj.group(1).replace("&amp;", "&")
        seq, bname, mds = mobj.group(2), html.unescape(mobj.group(3)).strip(), mobj.group(4)
        if seq in seen_seq:
            continue
        seen_seq.add(seq)
        if _DESTINY_SKIP.search(bname):
            continue
        try:
            mdate = dt.datetime.strptime(mds, "%m/%d/%Y").date()
        except ValueError:
            continue
        if mdate < cutoff:
            continue
        url = _DESTINY_BASE + href
        try:
            req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=30, context=_ctx) as r:
                ag = r.read().decode(errors="replace")
        except Exception:
            continue
        status = "On upcoming agenda" if mdate > today else f"Heard {mdate}"
        kept = 0
        for it in _agenda_items(ag):
            if kept >= GRAN_MAX_PER_MTG:
                break
            if _is_noise(it):
                continue
            tt = topics_for(it)
            if not tt or not (_substantive(it) or len(it) >= 60):
                continue
            key = (portal_id, it[:90].lower())
            if key in seen_titles:
                continue
            seen_titles.add(key)
            case = _CASE_RE.search(it)
            records.append({
                "city": name, "county": county, "topics": sorted(set(tt)),
                "file": case.group(0) if case else "",
                "type": bname, "status": status,
                "title": it[:240], "intro": "", "agenda": str(mdate),
                "enacted": "", "last_modified": str(mdate),
                "url": url, "source": "DestinyHosted",
            })
            kept += 1
    print(f"   - {name}: {len(records)} relevant items (DestinyHosted)")
    return records

