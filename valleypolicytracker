    "adu": ("ADUs / casitas", "housing",
        ["accessory dwelling", "accessory unit", "casita", "guest house", "guesthouse", "backyard home"]),
    "parking_reform": ("Parking reform", "housing",
        ["parking minimum", "parking requirement", "parking ratio", "off-street parking",
         "reduce parking", "eliminate parking", "parking reform", "parking standard"]),
    "tod": ("Transit-oriented development", "transit",
